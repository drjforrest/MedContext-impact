# Docker-specific environment configuration for MedContext
# Copy this to .env for Docker deployments: cp .env.docker .env

# Database (managed by docker-compose)
# PostgreSQL container credentials (update these for your deployment)
POSTGRES_USER=medcontext
POSTGRES_PASSWORD=medcontext_password
POSTGRES_DB=medcontext

# Backend connection string (must match the credentials above)
DATABASE_URL=postgresql://medcontext:medcontext_password@db:5432/medcontext

# MedGemma Configuration
MEDGEMMA_PROVIDER=huggingface
MEDGEMMA_HF_TOKEN=your_huggingface_token_here

# Alternative: Vertex AI (uses Application Default Credentials)
MEDGEMMA_PROVIDER=vertex
MEDGEMMA_VERTEX_PROJECT=medcontext
MEDGEMMA_VERTEX_LOCATION=us-central1
MEDGEMMA_VERTEX_ENDPOINT=mg-endpoint-29225930-0fc6-497a-bde5-a0d4c301c79d
MEDGEMMA_VERTEX_DEDICATED_DOMAIN=mg-endpoint-29225930-0fc6-497a-bde5-a0d4c301c79d.us-central1-307851807934.prediction.vertexai.goog

# Optional: LLM Orchestration
LLM_ORCHESTRATOR=
LLM_WORKER=
OPENROUTER_API_KEY=

# Optional: Reverse Image Search
SERP_API_KEY=

# Optional: Telegram Bot
TELEGRAM_BOT_TOKEN=

# Optional: Forensics (experimental)
ENABLE_FORENSICS=false
ENABLE_FORENSICS_MEDGEMMA=false

# Optional: Demo Protection (for public deployments)
# Leave empty for local development
# DEMO_ACCESS_CODE=MEDCONTEXT-DEMO-2026
VERTEX_ENDPOINT_ID=mg-endpoint-29225930-0fc6-497a-bde5-a0d4c301c79d
