# =============================================================================
# MedContext Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# QUICK START (Zero Configuration):
#   The system works out-of-the-box with local GGUF inference (no API keys needed)
#   Just run: ./scripts/setup_llama_cpp.sh
#   Then: docker-compose up -d
#
# PRODUCTION SETUP:
#   1. Choose MedGemma provider (Local GGUF, HuggingFace, or Vertex AI)
#   2. Choose LLM provider for orchestration (Gemini or OpenRouter)
#   3. Configure add-on modules (optional: reverse search, provenance, forensics)
# =============================================================================

# =============================================================================
# DATABASE CONFIGURATION (Required for Docker)
# =============================================================================
# PostgreSQL credentials (used by docker-compose)
POSTGRES_USER=medcontext
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=medcontext

# Database URL (auto-configured for Docker, or set manually for local dev)
# Docker: postgresql://medcontext:your_secure_password_here@db:5432/medcontext
# Local:  postgresql://postgres:postgres@localhost:5432/medcontext
# Docker default:
DATABASE_URL=postgresql://medcontext:your_secure_password_here@db:5432/medcontext
# Or for local dev:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/medcontext
# =============================================================================
# MEDGEMMA PROVIDER CONFIGURATION
# =============================================================================
# Choose ONE provider below. System auto-detects based on what's configured.
# Default: Local GGUF inference (zero external dependencies)
# =============================================================================

# Model identifier (auto-selects provider based on naming)
# - GGUF: "llama_cpp/medgemma-1.5-4b-it-Q4_K_M" (default, works offline)
# - HuggingFace: Use exact model ID from huggingface.co (e.g., "google/medgemma-4b-it")
# - Vertex AI: "mg-endpoint-xxxxx"
MEDGEMMA_MODEL=llama_cpp/medgemma-1.5-4b-it-Q4_K_M

# ─────────────────────────────────────────────────────────────────────────────
# OPTION A: Local GGUF Inference (DEFAULT - Recommended for Development)
# ─────────────────────────────────────────────────────────────────────────────
# No API keys needed. Runs entirely offline. Fast setup.
# Run: ./scripts/setup_llama_cpp.sh to download models
# ~2.4GB for Q4_K_M quantization (best quality/speed balance)

MEDGEMMA_LOCAL_PATH=models/medgemma-1.5-4b-it-Q4_K_M.gguf
MEDGEMMA_MMPROJ_PATH=models/mmproj-F16.gguf

# ─────────────────────────────────────────────────────────────────────────────
# OPTION B: HuggingFace Inference API (Production Ready)
# ─────────────────────────────────────────────────────────────────────────────
# Requires HuggingFace account + token (free tier available)
# Get token: https://huggingface.co/settings/tokens
# Uncomment and configure:

# MEDGEMMA_MODEL=google/medgemma-4b-it  # Use exact model ID from huggingface.co
# MEDGEMMA_HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─────────────────────────────────────────────────────────────────────────────
# OPTION C: Google Vertex AI (Enterprise Production)
# ─────────────────────────────────────────────────────────────────────────────
# Requires GCP account + deployed Vertex AI endpoint
# Best for: High throughput, low latency, enterprise SLAs
# Uncomment and configure:

# MEDGEMMA_MODEL=mg-endpoint-xxxxx
# MEDGEMMA_VERTEX_PROJECT=your-gcp-project-id
# MEDGEMMA_VERTEX_LOCATION=us-central1
# MEDGEMMA_VERTEX_ENDPOINT=https://us-central1-aiplatform.googleapis.com/v1/projects/PROJECT/locations/us-central1/endpoints/ENDPOINT
# VERTEX_API_KEY=your_vertex_api_key  # Optional: for key-based auth

# === Core Modules (always enabled, no configuration needed) ===
# Medical Image Analysis (MedGemma) and Contextual Authenticity are always on.

# === Add-on Modules (disabled by default) ===
# Reverse image search via SerpAPI. Requires SERP_API_KEY.
ENABLE_REVERSE_SEARCH=false
# Blockchain-style provenance tracking. Requires DATABASE_URL.
ENABLE_PROVENANCE=false
# Pixel-level forensics (ELA, EXIF analysis)
ENABLE_FORENSICS=false
# MedGemma semantic layer within forensics (optional, requires ENABLE_FORENSICS=true)
ENABLE_FORENSICS_MEDGEMMA=false

# SerpAPI key for reverse image search (required when ENABLE_REVERSE_SEARCH=true)
# SERP_API_KEY=

# Optional: Demo Protection (for public deployments)
# Leave empty for local development
# DEMO_ACCESS_CODE=MEDCONTEXT-DEMO-2026

# =============================================================================
# PRODUCTION SERVER: RATE LIMITING & ADMIN ACCESS
# =============================================================================
# Your IP address — bypasses ALL rate limits (use your static IP).
# Leave empty for local dev (no bypass needed).
# ADMIN_IP=

# Rate limit for llama-cpp requests (per hour, per IP).
# Lower than cloud providers because the local model is single-threaded.
# Default: 5.  Set higher for trusted private networks.
# LLAMA_CPP_RATE_LIMIT=5

# BYO GPU auto-revert timeout (seconds of inactivity before switching back to llama-cpp).
# Default: 120 (2 minutes).
# BYO_GPU_INACTIVITY_SECS=120
# =============================================================================

# =============================================================================
# LLM ORCHESTRATOR CONFIGURATION (Required for Contextual Analysis)
# =============================================================================
# The orchestrator LLM handles alignment analysis and claim verification.
# MedGemma provides medical expertise, LLM provides reasoning.
# =============================================================================

# ─────────────────────────────────────────────────────────────────────────────
# OPTION A: Google Gemini API (RECOMMENDED - Best Performance)
# ─────────────────────────────────────────────────────────────────────────────
# Free tier: 1500 requests/day for Gemini 2.5 Flash
# Get API key: https://aistudio.google.com/app/apikey

# LLM_PROVIDER=gemini
# GEMINI_API_KEY=your_gemini_api_key_here
# LLM_ORCHESTRATOR=gemini-2.5-pro      # Complex alignment reasoning
# LLM_WORKER=gemini-2.5-flash          # Fast text generation

# ─────────────────────────────────────────────────────────────────────────────
# OPTION B: OpenRouter (Multi-Provider Access)
# ─────────────────────────────────────────────────────────────────────────────
# Access GPT-4, Claude, Gemini, and more through one API
# Get API key: https://openrouter.ai/keys
# Uncomment to use:

# LLM_PROVIDER=openai_compatible
# OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_ORCHESTRATOR=anthropic/claude-3.5-sonnet
# LLM_WORKER=openai/gpt-4o-mini

# ─────────────────────────────────────────────────────────────────────────────
# FALLBACK: If no LLM API key is set, system falls back to MedGemma-only mode
# (Limited contextual reasoning, but still functional for medical analysis)
# ─────────────────────────────────────────────────────────────────────────────

# ─────────────────────────────────────────────────────────────────────────────
# Blockchain Provenance Anchoring (optional, requires ENABLE_PROVENANCE=true)
# ─────────────────────────────────────────────────────────────────────────────
# 1. Run: python scripts/deploy_contract.py
# 2. Fund wallet at: https://faucet.polygon.technology/
# 3. Set CONTRACT_ADDRESS to the deployed address printed by the script

ENABLE_BLOCKCHAIN_ANCHORING=false

# Option A: Local development (anvil/hardhat — no tokens needed)
# Run: anvil  (then deploy with scripts/deploy_contract.py)
# POLYGON_RPC_URL=http://127.0.0.1:8545
# ETHEREUM_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
# POLYGON_NETWORK=local

# Option B: Polygon Amoy testnet (current testnet, use faucet.polygon.technology)
# POLYGON_RPC_URL=https://rpc-amoy.polygon.technology
# POLYGON_NETWORK=amoy

# Option C: Polygon Mumbai testnet (deprecated but still works)
POLYGON_RPC_URL=https://rpc-mumbai.maticvigil.com
POLYGON_NETWORK=mumbai

ETHEREUM_PRIVATE_KEY=0x...your_private_key_here
CONTRACT_ADDRESS=0x...deployed_contract_address
